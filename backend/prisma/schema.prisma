generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS & AUTH ───────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  phone         String   @unique
  email         String?  @unique
  passwordHash  String
  businessName  String?
  displayName   String?
  pin           String?  // 4-digit transaction PIN hash
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wallet          Wallet?
  payments        Payment[]
  splitRules      SplitRule[]
  esusuMemberships EsusuMember[]
  ownedGroups     EsusuGroup[]       @relation("GroupOwner")
  emergencyVotes  EmergencyVote[]
  dailyReports    DailyReport[]

  @@map("users")
}

// ─── WALLET ─────────────────────────────────────────────────

model Wallet {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])

  // Naira balances (display currency) — stored as kobo (integer)
  nairaBalance     BigInt   @default(0)  // available Naira balance in kobo
  
  // USDC balances — stored as smallest unit (6 decimals, so micro-USDC)
  usdcSavings      BigInt   @default(0)  // personal vault USDC
  usdcPending      BigInt   @default(0)  // being settled on-chain

  // On-chain address (Base L2)
  baseAddress      String?  @unique
  // Encrypted private key (HSM in production)
  encryptedKey     String?

  totalInterestEarnedKobo BigInt @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions     Transaction[]

  @@map("wallets")
}

// ─── PAYMENTS (Naira inflows) ───────────────────────────────

model Payment {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])

  amountKobo     BigInt        // amount in kobo
  reference      String        @unique
  provider       PaymentProvider
  providerRef    String?
  status         PaymentStatus @default(PENDING)
  
  // Liquidity guarantee tracking
  receivedAt     DateTime      @default(now())
  settledAt      DateTime?
  bonusApplied   Boolean       @default(false) // true if >5min settlement

  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  splitExecutions SplitExecution[]

  @@index([userId, createdAt])
  @@map("payments")
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  BANK_TRANSFER
  INTERNAL
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  SETTLED      // USDC purchased and allocated
  FAILED
}

// ─── TRANSACTIONS (ledger) ──────────────────────────────────

model Transaction {
  id           String          @id @default(uuid())
  walletId     String
  wallet       Wallet          @relation(fields: [walletId], references: [id])

  type         TransactionType
  direction    Direction
  amountKobo   BigInt          // Naira equivalent
  amountUsdc   BigInt?         // USDC micro-units if applicable
  rateUsed     Decimal?        // NGN/USD rate at time of tx
  
  description  String?
  reference    String?         @unique
  status       TxStatus        @default(COMPLETED)

  relatedEsusuId String?

  createdAt    DateTime        @default(now())

  @@index([walletId, createdAt])
  @@map("transactions")
}

enum TransactionType {
  DEPOSIT          // Naira payment received
  WITHDRAWAL       // Naira withdrawn
  SAVE_TO_VAULT    // Naira → USDC personal vault
  VAULT_WITHDRAW   // USDC vault → Naira
  ESUSU_CONTRIBUTE // Contribution to group
  ESUSU_PAYOUT     // Payout from group
  EMERGENCY_PAYOUT // Emergency pot payout
  INTEREST_CREDIT  // Yield earned
  LIQUIDITY_BONUS  // 5-min guarantee bonus
  SPLIT_TRANSFER   // Auto-split allocation
}

enum Direction {
  CREDIT
  DEBIT
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

// ─── SMART SPLIT RULES ─────────────────────────────────────

model SplitRule {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  name        String   // e.g., "Default Split", "Big Sales Split"
  isActive    Boolean  @default(true)
  priority    Int      @default(0) // higher = checked first

  // Condition: only trigger if payment >= this amount (kobo). 0 = always
  minAmountKobo BigInt @default(0)

  // Allocations must sum to 10000 (100.00%)
  allocations SplitAllocation[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, isActive])
  @@map("split_rules")
}

model SplitAllocation {
  id          String         @id @default(uuid())
  ruleId      String
  rule        SplitRule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  target      SplitTarget
  percentage  Int            // basis points out of 10000 (e.g., 6000 = 60%)
  
  // If target is ESUSU_GROUP, which group?
  esusuGroupId String?
  esusuGroup   EsusuGroup?   @relation(fields: [esusuGroupId], references: [id])

  @@map("split_allocations")
}

enum SplitTarget {
  PERSONAL_VAULT  // Save to USDC vault
  NAIRA_BALANCE   // Keep as Naira
  ESUSU_GROUP     // Send to specific Esusu group
}

model SplitExecution {
  id          String   @id @default(uuid())
  paymentId   String
  payment     Payment  @relation(fields: [paymentId], references: [id])
  
  target      SplitTarget
  amountKobo  BigInt
  esusuGroupId String?
  executedAt  DateTime @default(now())

  @@map("split_executions")
}

// ─── ESUSU / AJO / CONTRIBUTION CIRCLES ────────────────────

model EsusuGroup {
  id              String       @id @default(uuid())
  name            String
  description     String?
  ownerId         String
  owner           User         @relation("GroupOwner", fields: [ownerId], references: [id])

  // Cycle config
  contributionAmountKobo BigInt       // fixed contribution per cycle
  cyclePeriod            CyclePeriod  // DAILY, WEEKLY, MONTHLY
  maxMembers             Int
  currentCycleNumber     Int          @default(0)
  
  // Payout schedule — rotating: each cycle one member gets the pot
  payoutOrder            String[]     // array of userId in payout sequence
  nextPayoutIndex        Int          @default(0)

  // Savings mode: USDC or NAIRA
  savingsMode            SavingsMode  @default(USDC)
  
  // Group USDC pot (micro-USDC)
  potBalanceUsdc         BigInt       @default(0)
  potBalanceKobo         BigInt       @default(0)

  // Emergency pot (percentage of each contribution, e.g. 500 = 5%)
  emergencyPotBps        Int          @default(500)
  emergencyPotUsdc       BigInt       @default(0)
  emergencyPotKobo       BigInt       @default(0)

  status                 GroupStatus  @default(FORMING)
  startDate              DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  members        EsusuMember[]
  contributions  EsusuContribution[]
  payouts        EsusuPayout[]
  emergencyRequests EmergencyRequest[]
  splitAllocations  SplitAllocation[]

  @@map("esusu_groups")
}

enum CyclePeriod {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum SavingsMode {
  USDC
  NAIRA
}

enum GroupStatus {
  FORMING    // accepting members
  ACTIVE     // cycles running
  COMPLETED  // all cycles done
  DISSOLVED  // ended early
}

model EsusuMember {
  id          String   @id @default(uuid())
  groupId     String
  group       EsusuGroup @relation(fields: [groupId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id])

  joinedAt    DateTime   @default(now())
  isActive    Boolean    @default(true)
  payoutPosition Int?    // position in payout rotation

  contributions EsusuContribution[]

  @@unique([groupId, userId])
  @@map("esusu_members")
}

model EsusuContribution {
  id          String   @id @default(uuid())
  groupId     String
  group       EsusuGroup @relation(fields: [groupId], references: [id])
  memberId    String
  member      EsusuMember @relation(fields: [memberId], references: [id])

  cycleNumber Int
  amountKobo  BigInt
  amountUsdc  BigInt?
  paidAt      DateTime   @default(now())
  status      ContributionStatus @default(PAID)

  @@unique([groupId, memberId, cycleNumber])
  @@index([groupId, cycleNumber])
  @@map("esusu_contributions")
}

enum ContributionStatus {
  PENDING
  PAID
  LATE
  MISSED
}

model EsusuPayout {
  id          String   @id @default(uuid())
  groupId     String
  group       EsusuGroup @relation(fields: [groupId], references: [id])
  recipientId String   // userId
  cycleNumber Int
  amountKobo  BigInt
  amountUsdc  BigInt?
  paidAt      DateTime @default(now())

  @@unique([groupId, cycleNumber])
  @@map("esusu_payouts")
}

// ─── EMERGENCY POT ──────────────────────────────────────────

model EmergencyRequest {
  id          String   @id @default(uuid())
  groupId     String
  group       EsusuGroup @relation(fields: [groupId], references: [id])
  requesterId String   // userId
  
  reason      String
  amountKobo  BigInt   // requested amount
  
  // Voting
  votesFor    Int      @default(0)
  votesAgainst Int     @default(0)
  totalEligible Int    // total members who can vote
  
  // Yield penalty (bps deducted from requester's next payout)
  yieldPenaltyBps Int  @default(200) // 2% default penalty
  
  status      EmergencyStatus @default(VOTING)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  expiresAt   DateTime // voting deadline

  votes       EmergencyVote[]

  @@map("emergency_requests")
}

enum EmergencyStatus {
  VOTING
  APPROVED
  REJECTED
  EXPIRED
  DISBURSED
}

model EmergencyVote {
  id          String   @id @default(uuid())
  requestId   String
  request     EmergencyRequest @relation(fields: [requestId], references: [id])
  voterId     String
  voter       User     @relation(fields: [voterId], references: [id])
  approve     Boolean
  votedAt     DateTime @default(now())

  @@unique([requestId, voterId])
  @@map("emergency_votes")
}

// ─── DAILY REPORTS ──────────────────────────────────────────

model DailyReport {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  reportDate  DateTime @db.Date
  
  totalReceivedKobo  BigInt @default(0)
  totalSavedKobo     BigInt @default(0)
  totalSavedUsdc     BigInt @default(0)
  interestEarnedKobo BigInt @default(0)
  esusuContributedKobo BigInt @default(0)
  
  // Group summary
  groupPotTotalKobo  BigInt @default(0)
  
  // Voice note URL (generated pidgin summary)
  voiceNoteUrl       String?
  
  generatedAt        DateTime @default(now())

  @@unique([userId, reportDate])
  @@map("daily_reports")
}

// ─── EXCHANGE RATES (cached) ────────────────────────────────

model ExchangeRate {
  id        String   @id @default(uuid())
  pair      String   // e.g., "NGN_USD"
  rate      Decimal  // e.g., 1650.00
  source    String
  fetchedAt DateTime @default(now())

  @@index([pair, fetchedAt])
  @@map("exchange_rates")
}

// ─── TREASURY POOL ──────────────────────────────────────────

model TreasuryLedger {
  id           String   @id @default(uuid())
  
  type         TreasuryTxType
  amountUsdc   BigInt
  amountKobo   BigInt?
  txHash       String?  // on-chain tx hash
  description  String?
  
  createdAt    DateTime @default(now())

  @@map("treasury_ledger")
}

enum TreasuryTxType {
  FUND             // add liquidity
  SETTLE_PAYMENT   // buy USDC for user
  PAYOUT           // sell USDC for Naira withdrawal
  YIELD_DEPOSIT    // yield earned from DeFi
  LIQUIDITY_ADVANCE // instant payout before settlement
}
