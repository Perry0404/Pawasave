# P-AUTO Vault Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# HARDHAT & TESTING CONFIGURATION
# ============================================

# Enable mainnet forking for tests (default: false)
FORKING=false

# ============================================
# NETWORK RPC ENDPOINTS
# ============================================

# Base Sepolia Testnet
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Mainnet
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# Private key of deployer account (KEEP SECRET!)
# Generate: `npx hardhat node` or use MetaMask export
DEPLOYER_PRIVATE_KEY=0x

# Existing token address (optional, will deploy MockERC20 if not provided)
CNGN_TOKEN_ADDRESS=

# Strategy contract addresses
PRIMARY_STRATEGY_ADDRESS=0x
FALLBACK_STRATEGY_ADDRESS=0x

# Recipient address for platform fees
FEE_RECIPIENT_ADDRESS=0x

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Public variables for frontend (no NEXT_PUBLIC_ prefix needed, added automatically)
NEXT_PUBLIC_PAUTO_VAULT_ADDRESS=0x
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_CHAIN_ID=84532

# ============================================
# OPTIONAL: ANALYTICS & VERIFICATION
# ============================================

# Gas reporting (default: false)
REPORT_GAS=false

# CoinMarketCap API key for gas reporting (get from https://coinmarketcap.com/api/)
COINMARKETCAP_API_KEY=

# Basescan API key for contract verification (get from https://basescan.org/)
BASESCAN_API_KEY=

# ============================================
# DEVELOPMENT
# ============================================

# Environment (development/staging/production)
NODE_ENV=development

# Debug mode
DEBUG=false
