# Supabase - get from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Paychant - get from https://developer.paychant.com
NEXT_PUBLIC_PAYCHANT_API_KEY=your_paychant_partner_api_key
NEXT_PUBLIC_PAYCHANT_ENV=sandbox
