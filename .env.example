# PawaSave — root (Hardhat / contracts / deploy / keeper) environment.
# Copy to `.env` and fill in. The Next.js app has its OWN env file:
# frontend/.env.local.example. This file covers contract deployment, the
# operational keeper scripts, and Hardhat tests only.
#
# SECURITY: never commit a filled-in .env. DEPLOYER_PRIVATE_KEY and the keeper
# keys control real funds. In production these are loaded from AWS Secrets
# Manager (see frontend/src/lib/secrets.ts), not from plain env.

# ============================================
# HARDHAT & TESTING
# ============================================
# Enable mainnet forking for tests (needs BASE_MAINNET_RPC_URL).
FORKING=false
# Gas reporting in tests.
REPORT_GAS=false
COINMARKETCAP_API_KEY=
NODE_ENV=development
DEBUG=false

# ============================================
# NETWORK RPC ENDPOINTS
# ============================================
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
# Optional comma-separated extra Base RPCs used by the FallbackProvider
# (V2-INFRA-04) so one dead endpoint doesn't take the keepers offline.
BASE_RPC_FALLBACKS=

# ============================================
# DEPLOYMENT (KEEP SECRET)
# ============================================
# Deployer EOA private key. NOTE: the current deployer key is considered
# exposed — contract ownership has been moved to the Gnosis Safe; rotate this
# key out of the signer set. Used by hardhat.config.ts for baseMainnet/Sepolia.
DEPLOYER_PRIVATE_KEY=0x
# Recipient of protocol/platform fees.
FEE_RECIPIENT_ADDRESS=0x
# Lend insurance fund recipient (deploy-lend.ts; defaults to fee recipient).
INSURANCE_FUND_ADDRESS=0x
# Safe (or hardware wallet) that should own the contracts after deploy.
# Used by scripts/transfer-ownership.ts.
NEW_OWNER=0x04A68bB3056D95fFD64FE681f442BCfc04c79109

# ============================================
# TOKEN ADDRESSES (Base mainnet defaults shown)
# ============================================
CNGN_TOKEN_ADDRESS=0x46C85152bFe9f96829aA94755D9f915F9B10EF5F
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDT_TOKEN_ADDRESS=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2

# ============================================
# DEPLOYED CONTRACT ADDRESSES
# Filled in after each deploy; deploy scripts REUSE these to avoid redeploying
# dependencies and to wire ownership transfers.
# ============================================
PAWASAVE_LEND_ADDRESS=0x
PRICE_ORACLE_ADDRESS=0x
CREDIT_LINE_ADDRESS=0x
PAUTO_VAULT_ADDRESS=0x
IRM_ADDRESS=0x
LEND_POOL_ADDRESS=0x
PRIMARY_STRATEGY_ADDRESS=0x
FALLBACK_STRATEGY_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================
# LEND POOL CONFIG
# ============================================
# Oracle keeper EOA authorised to push prices (address only; key below).
ORACLE_KEEPER_ADDRESS=0x
# Per-user borrow cap in whole cNGN (deploy-lend.ts). Default ₦200,000,000.
MAX_BORROW_PER_USER_CNGN=200000000

# ============================================
# COLLATERAL CONFIG (scripts/add-collateral.ts)
# ============================================
NGN_PER_USD=1650
USDT_LTV=
TBILL_TOKEN_ADDRESS=
TBILL_DECIMALS=
TBILL_LTV=
TBILL_PRICE_CNGN=
RWA_TOKEN_ADDRESS=
RWA_DECIMALS=
RWA_LTV=
RWA_PRICE_CNGN=

# ============================================
# KEEPER SCRIPTS (scripts/oracle-keeper.ts) — KEEP SECRET
# In production these live in AWS Secrets Manager, not here.
# ============================================
ORACLE_KEEPER_PRIVATE_KEY=0x
FLINT_API_KEY=

# ============================================
# CONTRACT VERIFICATION
# ============================================
BASESCAN_API_KEY=

# ============================================
# FRONTEND PUBLIC VARS (mirrored; see frontend/.env.local.example)
# ============================================
NEXT_PUBLIC_PAUTO_VAULT_ADDRESS=0x
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_CHAIN_ID=8453