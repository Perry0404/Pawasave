# ---- PawaSave Backend Environment ----
# Copy to .env and fill in real values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/pawasave?schema=public"

# Redis (for BullMQ job queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# Base L2 (USDC on Base)
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
TREASURY_WALLET_PRIVATE_KEY=your-treasury-wallet-private-key
TREASURY_WALLET_ADDRESS=your-treasury-wallet-address

# Naira exchange rate provider (e.g., Quidax, Flutterwave)
EXCHANGE_RATE_API_URL=https://api.example.com/rates
EXCHANGE_RATE_API_KEY=your-api-key

# Fiat on/off ramp (Flutterwave / Paystack)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Interest / Yield
ANNUAL_YIELD_RATE_BPS=500
# 500 bps = 5% APY — from DeFi yield or treasury strategy

# Liquidity guarantee
LIQUIDITY_BONUS_YIELD_BPS=50
# Extra 0.5% yield if settlement takes > 5 mins

# App
PORT=3000
NODE_ENV=development
