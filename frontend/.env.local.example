# Supabase - get from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (for webhook handler)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# FlintAPI - get from https://console.flintapi.io
FLINT_API_KEY=your_flint_api_key_here
FLINT_WEBHOOK_SECRET=your_webhook_secret_here

# Base L2 wallet address where on-ramp stablecoins are collected
# Create a wallet at console.flintapi.io or use any Base wallet
FLINT_CUSTODY_ADDRESS=your_base_wallet_address_here

# Optional legacy shared destination wallet for partner on-ramp providers
RAMP_CUSTODY_ADDRESS=your_base_wallet_address_here
RAMP_BENEFICIARY_NAME=PawaSave Treasury

# Xend merchant API
# Important: XEND_PUBLIC_KEY is the public PEM you upload to Xend or use for webhook verification.
# XEND_PRIVATE_KEY must be the matching private PEM used to sign merchant API requests.
# A PUBLIC KEY block is not sufficient for XEND_PRIVATE_KEY.
XEND_ACTIVE=false
XEND_BASE_URL=https://api-solid-staging.xend.africa
XEND_MERCHANT_ID=your_xend_merchant_id_here
XEND_API_KEY=your_xend_api_key_here
XEND_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
XEND_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
XEND_CUSTODY_ADDRESS=your_xend_base_wallet_address_here

# ─── Ramp providers ───────────────────────────────────────────────────────────
# PawaSave uses Flipeet only (cNGN end-to-end). Flint and Xend stay OFF until you
# explicitly opt in, even if their keys are present.
FLINT_ENABLED=false
XEND_ENABLED=false

# ─── Crypto deposits (per-user HD wallets + auto-indexer) ─────────────────────
# Master seed used to derive each user's unique Base cNGN deposit address at
# m/44'/60'/0'/0/{deposit_index}. PawaSave controls these keys. KEEP IT SECRET —
# never expose with NEXT_PUBLIC. A 12/24-word BIP-39 mnemonic.
DEPOSIT_WALLET_MNEMONIC="word1 word2 ... word12"

# ─── Deposit sweep (CRIT-03 mitigation) ───────────────────────────────────────
# After deposits are credited, the sweep cron drains cNGN out of the per-user HD
# deposit addresses into ONE custody address, so the hot deposit wallets never
# accumulate user funds (a mnemonic leak then yields ~nothing). The cron is a
# no-op until DEPOSIT_SWEEP_DESTINATION is set.
# Point this at a COLD address (hardware wallet / Safe) for best security.
DEPOSIT_SWEEP_DESTINATION=
# Hot wallet that pays gas to top up deposit addresses before each sweep.
# Defaults to CUSTODY_PRIVATE_KEY if unset. Keep it funded with a little ETH on Base.
DEPOSIT_GAS_FUNDER_PRIVATE_KEY=
# Don't bother sweeping below this many micro-cNGN (default 100 cNGN = 100000000).
DEPOSIT_SWEEP_MIN_CNGN=100000000
# Max addresses to sweep per cron run (safety bound; default 10).
DEPOSIT_SWEEP_MAX=10

# ─── AWS Secrets Manager (move secrets out of plain env) ──────────────────────
# When AWS_SECRETS_ID is set, the deposit mnemonic + operational private keys are
# read from ONE AWS secret (a JSON object keyed by the var names below) instead
# of these env vars. Anything missing from the secret falls back to env, so this
# is safe to roll out gradually and for local dev. Leave AWS_SECRETS_ID unset to
# stay in pure-env mode.
#   Secret JSON shape:
#   { "DEPOSIT_WALLET_MNEMONIC": "...", "CUSTODY_PRIVATE_KEY": "0x...",
#     "ORACLE_KEEPER_PRIVATE_KEY": "0x...", "LIQUIDATION_KEEPER_PRIVATE_KEY": "0x...",
#     "VAULT_HARVESTER_PRIVATE_KEY": "0x...", "DEPOSIT_GAS_FUNDER_PRIVATE_KEY": "0x..." }
AWS_SECRETS_ID=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Flipeet partner API
FLIPEET_ACTIVE=false
FLIPEET_API_KEY=your_flipeet_api_key_here
FLIPEET_BASE_URL=https://api.pay.flipeet.io/api/v1/public
FLIPEET_CUSTODY_ADDRESS=your_flipeet_destination_wallet_here
FLIPEET_NETWORK=base
# PawaSave settles on/off-ramp in cNGN end-to-end (never USDC). Keep this 'cngn'.
FLIPEET_ASSET=cngn
FLIPEET_FIAT_CURRENCY=NGN
FLIPEET_COUNTRY_CODE=NG
# Webhook authenticity (FIND-API-01): a random secret embedded in the callback
# URL we hand Flipeet. The /api/flipeet-webhook handler rejects any request that
# doesn't carry it. REQUIRED — the webhook fails closed (503) if unset. Generate
# with e.g. `openssl rand -hex 32`.
FLIPEET_WEBHOOK_TOKEN=

# Private key controlling FLIPEET_CUSTODY_ADDRESS. Signs on-chain cNGN transfers
# (off-ramp payouts) and supply/withdraw to PawasaveLend. Fund with ~0.05 ETH on
# Base for gas — it signs the most transactions of any operational wallet.
CUSTODY_PRIVATE_KEY=0x

# ─── P-AUTO Vault (on-chain fixed savings) ────────────────────────────────────
# Deployed by: npm run deploy:mainnet (from project root)
# Step 1: deploy lending pool → get PRICE_ORACLE_ADDRESS + PAWASAVE_LEND_ADDRESS
# Step 2: deploy vault → get PAUTO_VAULT_ADDRESS
NEXT_PUBLIC_PAUTO_VAULT_ADDRESS=0x7F64f8B73C11456bF84B89C9944A501049D78Ab2
NEXT_PUBLIC_CNGN_TOKEN_ADDRESS=0x46C85152bFe9f96829aA94755D9f915F9B10EF5F
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_CHAIN_ID=8453
# Server-side RPC used by cron jobs (harvest-vault) and the oracle keeper.
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ─── Protocol collateral tokens (frontend selector) ───────────────────────────
# A token is selectable once its address is set AND it is listed on-chain via
# scripts/add-collateral.ts (which also sets its PriceOracle price).
NEXT_PUBLIC_USDT_TOKEN_ADDRESS=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2
# Tokenized T-bills (leave blank until you have a Base address):
NEXT_PUBLIC_TBILL_TOKEN_ADDRESS=
NEXT_PUBLIC_TBILL_DECIMALS=18
# Tokenized real-world asset (leave blank until you have a Base address):
NEXT_PUBLIC_RWA_TOKEN_ADDRESS=
NEXT_PUBLIC_RWA_DECIMALS=18

# Vault keeper wallet — must hold HARVESTER_ROLE on PawasaveAutoVault
# Fund with ~0.01 ETH on Base for gas. Never use your main wallet.
VAULT_HARVESTER_PRIVATE_KEY=0x

# ─── PawaSave Lending Pool (P-AUTO strategy) ──────────────────────────────────
# Deployed by: npm run deploy:lend (from project root)
PAWASAVE_LEND_ADDRESS=0x
PRICE_ORACLE_ADDRESS=0x
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Oracle keeper wallet — must hold keeper role on PriceOracle
# Separate from vault keeper. Fund with ~0.01 ETH on Base for gas.
ORACLE_KEEPER_PRIVATE_KEY=0x
# Liquidation keeper (backstop for overdue/under-collateralised loans).# Must hold cNGN (to repay debt) + ETH (gas). Earns the liquidation bonus.LIQUIDATION_KEEPER_PRIVATE_KEY=0x

# Vercel Cron secret — set this in Vercel dashboard → Environment Variables
# Used to secure /api/cron/* endpoints
CRON_SECRET=your_random_secret_here
# --- Rate limiting (persistent, survives serverless cold starts) ---# Optional but recommended for production (FIND-API-05). Free Upstash Redis -> REST API.# Without these, the limiter falls back to in-memory.UPSTASH_REDIS_REST_URL=UPSTASH_REDIS_REST_TOKEN=

# ─── Xend X-AUTO (production) ────────────────────────────────────────────────
# Switch from staging to production when you go live with X-AUTO
# Live base URL (replace staging URL above):
# XEND_BASE_URL=https://api-solid.xend.africa
# Production currency IDs (may differ from staging — run get-prod-currencies.mjs to fetch)
XEND_CURRENCY_ID_USDC=
XEND_CURRENCY_ID_CNGN=
# Base network ID from Xend merchant dashboard → Developer → Networks
XEND_NETWORK_ID_BASE=
