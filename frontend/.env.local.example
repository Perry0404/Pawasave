# Supabase - get from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (for webhook handler)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# FlintAPI - get from https://console.flintapi.io
FLINT_API_KEY=your_flint_api_key_here
FLINT_WEBHOOK_SECRET=your_webhook_secret_here
